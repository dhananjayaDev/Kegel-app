# Flask
FLASK_SECRET_KEY=change-me-to-a-random-secret
FLASK_DEBUG=1
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Deployment: web | desktop | android (controls LLM auto-detection)
APP_DEPLOYMENT=web

# LLM provider: auto | ollama | gemini | template
# web hosted site: auto uses Gemini when GEMINI_API_KEY is set
# desktop/android: auto prefers local Ollama, then Gemini if configured
LLM_PROVIDER=auto

# Local Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Hosted web app — required for cloud plans on the public site
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Download links (optional — auto-detected from dist/ when running locally)
# For production, point desktop to a GitHub Release asset URL:
# DESKTOP_APP_URL=https://github.com/you/kegelapp/releases/download/v1.0.0/KegelHealth.exe
DESKTOP_APP_URL=
MOBILE_APP_URL=

# PostgreSQL (Render: use Internal URL on web service, External URL locally)
DATABASE_URL=
